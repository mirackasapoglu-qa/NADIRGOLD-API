{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OtpRequiredResponse",
  "type": "object",
  "required": ["success", "data"],
  "properties": {
    "success": { "const": true },
    "data": {
      "type": "object",
      "required": ["requiresOtp", "hash"],
      "properties": {
        "requiresOtp": { "const": true },
        "hash": { "type": "string", "minLength": 1 }
      }
    }
  }
}
