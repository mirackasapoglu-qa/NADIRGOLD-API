                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token eksik/gecersiz",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
