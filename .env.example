# --- Baglanti ---
# Canli V2 (portsuz; :3001 Cloudflare arkasinda calismiyor). Bos birakilirsa
# conftest bu adresi varsayilan kullanir; yani .env olmadan da testler kosar.
BASE_URL=https://api-v2.nadirgold.dev
TIMEOUT=15

# --- Test hesabi (login/logout/profil/authli sepet testleri icin) ---
# OTP'si KAPALI bir test hesabi kullan, aksi halde login OTP hash doner ve
# authli testler otomatik atlanir.
TEST_EMAIL=
TEST_PASSWORD=

# --- Negatif senaryolar icin (kayitli OLMAYAN degerler) ---
UNKNOWN_EMAIL=nonexistent_user_qa@example.com
WRONG_PASSWORD=definitely-wrong-password

# --- Sepet testleri ---
# Gecerli bir urun SKU'su (dokumanda ornek: ALTIN-GRAM-1)
TEST_SKU=ALTIN-GRAM-1
